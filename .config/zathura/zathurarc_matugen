# Zathura Material You Theme
set default-bg           "#0e1416"
set default-fg           "#dee3e5"
set statusbar-bg        "#1b2122"
set statusbar-fg        "#bfc8ca"
set inputbar-bg         "#252b2c"
set inputbar-fg         "#83d2e3"

# PDF Recoloring (Dark Mode / Midnight Mode)
set recolor             "true"
set recolor-lightcolor  "rgba(14, 20, 22, 1)"
set recolor-darkcolor   "#dee3e5"
set recolor-keephue     "true" 
