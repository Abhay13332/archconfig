# HTOP Color Configuration Template
# This template generates a custom htoprc configuration with themed colors
# Colors are defined using terminal color codes (0-255) or RGB hex values

# htoprc configuration with custom colors
fields=0 48 17 18 38 39 40 2 46 47 49 1
sort_key=46
sort_direction=-1
tree_sort_key=0
tree_sort_direction=1
hide_kernel_threads=1
hide_userland_threads=0
shadow_other_users=0
show_thread_names=0
show_program_path=1
highlight_base_name=0
highlight_deleted_exe=1
highlight_megabytes=1
highlight_threads=1
highlight_changes=0
highlight_changes_delay_secs=5
find_comm_in_cmdline=1
strip_exe_from_cmdline=1
show_merged_command=0
tree_view=0
tree_view_always_by_pid=0
all_branches_collapsed=0
header_margin=1
detailed_cpu_time=0
cpu_count_from_one=0
show_cpu_usage=1
show_cpu_frequency=0
show_cpu_temperature=0
degree_fahrenheit=0
update_process_names=0
account_guest_in_cpu_meter=0
color_scheme=6

# Custom color definitions using template variables
# Main interface colors
color_background=#030303
color_text=#e5e5e5
color_highlight=#c6c6c6
color_selected=#070707

# CPU meter colors (gradient)
color_cpu_low=#b5e9e9
color_cpu_med=#ecf3f0
color_cpu_high=#9db5e2

# Memory meter colors
color_mem_used=#8fc5d7
color_mem_buffers=#c3e6ea
color_mem_cache=#9fcfdb
color_mem_available=#b5e9e9

# Process list colors
color_process_normal=#e5e5e5
color_process_running=#b5e9e9
color_process_sleeping=#767676
color_process_zombie=#9db5e2
color_process_stopped=#ecf3f0

# Header and border colors
color_header=#ababab
color_border=#767676
color_separator=#484848

# Function key colors
color_function_key=#f7f7f7
color_function_desc=#e5e5e5

# Tree view colors
color_tree_line=#767676
color_tree_collapsed=#c6c6c6
color_tree_expanded=#9d9d9d

# Load average colors
color_load_low=#b5e9e9
color_load_med=#ecf3f0
color_load_high=#9db5e2

# Priority colors
color_priority_high=#9db5e2
color_priority_normal=#e5e5e5
color_priority_low=#767676

# Swap meter colors
color_swap_used=#b7bed5
color_swap_cache=#bed4bc

# Temperature colors (if enabled)
color_temp_cool=#b5e9e9
color_temp_warm=#ecf3f0
color_temp_hot=#9db5e2
